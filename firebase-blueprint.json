{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "name": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile photo URL." },
        "theme": { "type": "string", "enum": ["dark", "light"], "description": "User's preferred app theme." },
        "currency": { "type": "string", "description": "User's preferred currency symbol (e.g., $, €, £)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID." },
        "uid": { "type": "string", "description": "Owner's user ID." },
        "amount": { "type": "number", "description": "Transaction amount." },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction." },
        "category": { "type": "string", "description": "Category name." },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date." },
        "description": { "type": "string", "description": "Transaction description." },
        "icon": { "type": "string", "description": "Icon identifier." }
      },
      "required": ["uid", "amount", "type", "category", "date", "description"]
    },
    "RecurringBill": {
      "title": "RecurringBill",
      "description": "A recurring bill or subscription.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID." },
        "uid": { "type": "string", "description": "Owner's user ID." },
        "name": { "type": "string", "description": "Name of the bill." },
        "amount": { "type": "number", "description": "Amount." },
        "dueDate": { "type": "integer", "description": "Day of the month (1-31)." },
        "category": { "type": "string", "description": "Category." },
        "icon": { "type": "string", "description": "Icon identifier." }
      },
      "required": ["uid", "name", "amount", "dueDate"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Stores user profile data."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stores financial transactions."
    },
    "/recurringBills/{billId}": {
      "schema": "RecurringBill",
      "description": "Stores recurring bills."
    }
  }
}
